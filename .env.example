# Paste into Vercel → Project → Settings → Environment Variables (Production + Preview).
# Never commit a real key. Do not use the VITE_ prefix — that exposes keys to the browser.
ANTHROPIC_API_KEY=

# Local dev: run `npx vercel dev` and point the Vite app at that origin, e.g.:
# VITE_ORACLE_BASE_URL=http://localhost:3000
